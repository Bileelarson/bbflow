# --- Telegram ---
TELEGRAM_BOT_TOKEN=put-your-token-here
ADMIN_TELEGRAM_IDS=123456789                # comma-separated for multiple admins

# --- Free-tier image engine (OpenAI-compatible /v1/images/generations) ---
# Default points at a local 9router; replace with OpenAI direct, OpenRouter,
# or any compatible endpoint that streams b64_json over SSE.
FREE_API_BASE=http://127.0.0.1:20128/v1
FREE_API_KEY=
FREE_IMAGE_MODEL=cx/gpt-5.4-image

# --- Prompt enhance / random LLM (OpenAI-compatible /v1/chat/completions) ---
PROMPT_LLM_BASE=http://127.0.0.1:20128/v1
PROMPT_LLM_KEY=
PROMPT_ENHANCE_MODEL=kr/claude-haiku-4.5
PROMPT_RANDOM_MODEL=kr/deepseek-3.2

# --- Premium engine (your own provider — wire scripts under bot/) ---
# Override only if you place engine scripts outside bot/
# GEN_IMAGE_PREMIUM_PY=/abs/path/to/gen_image_one.py
# GEN_VIDEO_PREMIUM_PY=/abs/path/to/gen_video_one.py
# CHECK_BALANCE_PY=/abs/path/to/check_balance_one.py
# GEN_IMAGE_FREE_PY=/abs/path/to/gen_image_free.py

# --- Optional paths ---
# IMAJIN_DATA_DIR=./data                   # default: ./data
# IMAJIN_DB_PATH=./data/users.db
# IMAJIN_OUT_DIR=./data/out
# IMAJIN_QRIS_PATH=./assets/qris.jpg
# IMAJIN_CATALOG_DIR=./data/catalog
# IMAJIN_PYTHON_BIN=/path/to/venv/bin/python   # used to spawn engine subprocesses
